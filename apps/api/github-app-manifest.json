{
  "name": "ForkBot",
  "url": "https://forkbot.dev",
  "hook_attributes": {
    "url": "https://forkguard.dev/webhooks/github",
    "active": true
  },
  "public": true,
  "default_events": [
    "pull_request",
    "issue_comment",
    "installation",
    "installation_repositories",
    "push"
  ],
  "default_permissions": {
    "pull_requests": "write",
    "checks": "write",
    "contents": "read",
    "issues": "write",
    "metadata": "read"
  },
  "request_oauth_on_install": true,
  "setup_url": "https://forkbot.dev",
  "description": "AI-powered PR review that understands your codebase before reviewing changes."
}
